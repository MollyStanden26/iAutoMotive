// ============================================================
// iAutoMotive — Prisma Schema
// Database:  MongoDB
// ORM:       Prisma 5.x
// Storage:   Cloudflare R2 (images & documents)
// Cache:     Redis (Docker, same server)
// Domains:   11  |  Collections: 47  |  Enums: 40
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

