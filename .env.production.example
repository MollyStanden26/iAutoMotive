# Required in Vercel before first deploy.
# Set these in: Vercel project → Settings → Environment Variables (Production scope).

# ── Database ─────────────────────────────────────────────────────────
# Pooled connection string from Neon (or RDS / Supabase / Railway).
# Use the *pooled* URL for runtime, not the direct one.
DATABASE_URL=

# ── Auth (REQUIRED) ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=

# ── Public ───────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://iautomotive.co.uk
# Leave unset (or "false") in production. Setting to "true" exposes the
# Quick Demo Access role buttons on the signin page.
NEXT_PUBLIC_SHOW_DEMO=false

# ── External services (fill as you integrate) ────────────────────────
ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_IDENTITY_SECRET=
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=
HPI_API_KEY=
CAZANA_API_KEY=
DVLA_API_KEY=
ROUTEONE_API_KEY=
POINT_PREDICTIVE_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
