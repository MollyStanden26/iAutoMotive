# Database
DATABASE_URL=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Anthropic Claude API — all AI agents
ANTHROPIC_API_KEY=

# OpenAI — historically used for a second-pass image refinement; the
# photo editor now uses a deterministic PhotoRoom-segment + sharp-
# composite pipeline that produces consistent output without re-rendering
# the car body. Key kept here for future flows (Claude/OpenAI text agents).
OPENAI_API_KEY=

# Stripe Connect — payments + payouts
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Identity — KYC
STRIPE_IDENTITY_SECRET=

# DocuSign — e-signatures
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=

# Twilio — SMS + calls
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid — email
SENDGRID_API_KEY=

# HPI Check — vehicle history
HPI_API_KEY=

# Cazana — vehicle valuations
CAZANA_API_KEY=

# DVLA — V5C + VIN decode
DVLA_API_KEY=

# RouteOne — finance (FCA status required)
ROUTEONE_API_KEY=

# Point Predictive — fraud detection
POINT_PREDICTIVE_API_KEY=

# Vercel Blob — vehicle photos + consignment PDFs (production storage)
# In dev, leave empty: src/lib/storage/upload.ts falls back to public/uploads/.
# In Vercel: dashboard → Storage → Create → Blob → Connect to project.
# This auto-injects BLOB_READ_WRITE_TOKEN. No code changes needed to enable.
BLOB_READ_WRITE_TOKEN=

# PhotoRoom — segments the car out of raw photos for the photo editor.
# We use only the segmentation step (transparent cutout + soft shadow);
# compositing onto the backdrop happens deterministically via sharp so
# the car's pixels are never re-rendered.
PHOTOROOM_API_KEY=

# AWS — legacy S3 media storage placeholder; not currently used.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
