# Database
DATABASE_URL=

# Auth
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Anthropic Claude API — all AI agents
ANTHROPIC_API_KEY=

# OpenAI — gpt-image-1 second-pass refinement on the photo editor.
# After PhotoRoom replaces the background, the route hands the result to
# OpenAI's image-edit endpoint to re-ground the tyres on the floor and
# match the lighting on the car body to the backdrop.
# When this key is unset, the photo editor still works — it just ships
# the PhotoRoom-only output. Set OPENAI_IMAGE_QUALITY=low|medium|high|auto
# to override the default ("high"). High quality is ~$0.17/image.
OPENAI_API_KEY=
OPENAI_IMAGE_QUALITY=

# Stripe Connect — payments + payouts
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Identity — KYC
STRIPE_IDENTITY_SECRET=

# DocuSign — e-signatures
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=

# Twilio — SMS + calls
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid — email
SENDGRID_API_KEY=

# HPI Check — vehicle history
HPI_API_KEY=

# Cazana — vehicle valuations
CAZANA_API_KEY=

# DVLA — V5C + VIN decode
DVLA_API_KEY=

# RouteOne — finance (FCA status required)
ROUTEONE_API_KEY=

# Point Predictive — fraud detection
POINT_PREDICTIVE_API_KEY=

# Vercel Blob — vehicle photos + consignment PDFs (production storage)
# In dev, leave empty: src/lib/storage/upload.ts falls back to public/uploads/.
# In Vercel: dashboard → Storage → Create → Blob → Connect to project.
# This auto-injects BLOB_READ_WRITE_TOKEN. No code changes needed to enable.
BLOB_READ_WRITE_TOKEN=

# PhotoRoom — background-replacement for vehicle photos.
# Used by /admin/photo-editor → POST /api/admin/photos/replace-background.
# Get a key at https://www.photoroom.com/api → Dashboard → API keys.
# Optionally set PHOTOROOM_BACKDROP_URL to a public image URL (e.g. a Vercel
# Blob URL of the iAutoMotive showroom backdrop) to composite onto that
# instead of a flat colour.
PHOTOROOM_API_KEY=
PHOTOROOM_BACKDROP_URL=

# AWS — legacy S3 media storage placeholder; not currently used.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=
